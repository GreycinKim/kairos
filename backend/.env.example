# Use 127.0.0.1 on Windows if `localhost` resolves to IPv6 and hits a different Postgres than Docker.
DATABASE_URL=postgresql+asyncpg://kairos:kairos@127.0.0.1:5433/kairos
SYNC_DATABASE_URL=postgresql://kairos:kairos@127.0.0.1:5433/kairos
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app
JWT_SECRET=change-me-in-production
